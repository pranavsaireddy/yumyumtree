# apps/api/.env — backend configuration (architecture §11)
# Copy to .env and fill in real values. NEVER commit the real .env.

# ── Required (config.js exits at boot if any of these are missing) ───────────
PORT=4000
FRONTEND_URL=http://localhost:3000
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
APP_ENV=development            # one of: development | test | production

# ── Optional for now (config logs a single warning listing any that are unset)
# Wired up in their own sessions; safe to leave blank during platform work.
DATABASE_URL=                  # Supabase DIRECT string (port 5432) — pg-boss, S9
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
PETPOOJA_API_KEY=
PETPOOJA_API_SECRET=
PETPOOJA_APP_KEY=
PETPOOJA_RESTAURANT_ID=
SHADOWFAX_CLIENT_CODE=
SHADOWFAX_API_KEY=
SHADOWFAX_PICKUP_LAT=
SHADOWFAX_PICKUP_LNG=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_VERIFY_TOKEN=
SENTRY_DSN=
